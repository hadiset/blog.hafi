</style>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const mainHeader = document.getElementById('main-header');

  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    
    if (isMenuOpen) {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none', '-translate-y-10');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
      menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none', '-translate-y-10');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
      menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger icon
      document.body.style.overflow = '';
    }
  }

  menuToggle.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (isMenuOpen && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) {
      toggleMenu();
    }
  });

  // Close on link click
  const mobileLinks = document.querySelectorAll('.mobile-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  // Header scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      mainHeader.classList.add('bg-white/90', 'py-4', 'shadow-md');
      mainHeader.classList.remove('py-8', 'bg-transparent');
    } else {
      mainHeader.classList.remove('bg-white/90', 'py-4', 'shadow-md');
      mainHeader.classList.add('py-8', 'bg-transparent');
    }
  });

  // Partner carousel dots
  const partnerCarousel = document.getElementById('partner-carousel');
  const partnerDots = document.querySelectorAll('.partner-dot');
  if (partnerCarousel && partnerDots.length) {
    const itemsPerView = 2;
    const totalDots = partnerDots.length;
    partnerDots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        const scrollTarget = i * itemsPerView * (partnerCarousel.scrollWidth / partnerCarousel.children.length);
        partnerCarousel.scrollTo({ left: scrollTarget, behavior: 'smooth' });
      });
    });
    partnerCarousel.addEventListener('scroll', () => {
      const itemWidth = partnerCarousel.scrollWidth / partnerCarousel.children.length;
      const activeIndex = Math.round(partnerCarousel.scrollLeft / (itemWidth * itemsPerView));
      partnerDots.forEach((dot, i) => {
        if (i === activeIndex) {
          dot.classList.remove('bg-wo-sage/40');
          dot.classList.add('bg-wo-terracotta');
        } else {
          dot.classList.remove('bg-wo-terracotta');
          dot.classList.add('bg-wo-sage/40');
        }
      });
    });
  }
</script>
